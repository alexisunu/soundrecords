  flex-shrink: 0;
}
.store-coins .coins-val {
  font-size: 28px;
  font-weight: 700;
  font-family: 'Space Grotesk', sans-serif;
  color: #ffba00;
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: flex-end;
}
