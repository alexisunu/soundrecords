<div class="feed-layout">
  <main class="main">
    <div class="topbar">
      <div class="topbar-row">
        <h1>Inicio</h1>
        <div class="search-wrap">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7" />
            <path d="M21 21l-4.3-4.3" />
          </svg>
          <input type="text" placeholder="Buscar álbumes, artistas o usuarios…" />
        </div>
        <button class="icon-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8a6 6 0 10-12 0c0 5-2 6-2 6h16s-2-1-2-6z" />
            <path d="M9.5 20a2.5 2.5 0 005 0" />
          </svg>
          <span class="dot-alert"></span>
        </button>
        <div class="avatar-sm"></div>
      </div>
      <div class="feed-tabs">
        <div class="feed-tab" [class.active]="activeTab === 'following'" (click)="selectTab('following')">
          Siguiendo
        </div>
        <div class="feed-tab" [class.active]="activeTab === 'trending'" (click)="selectTab('trending')">
          Tendencias
        </div>
        <div class="feed-tab" [class.active]="activeTab === 'new-releases'" (click)="selectTab('new-releases')">
          Nuevos lanzamientos
        </div>
      </div>
    </div>

    <div class="feed">
      <div class="suggest-banner">
        <div class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4" />
            <path d="M4 21c0-4 3.5-7 8-7s8 3 8 7" />
            <path d="M19 8v6M16 11h6" />
          </svg>
        </div>
        <div class="txt">
          <strong>Tu feed está un poco vacío</strong>
          <p>Sigue a más oyentes y artistas para llenarlo de reseñas.</p>
        </div>
        <button class="cta">Buscar a quién seguir</button>
      </div>

      <ng-container *ngIf="activeTab === 'following'; else pendingTab">
        <div class="feed-status" *ngIf="loading">Cargando tu feed…</div>
        <div class="feed-status error" *ngIf="!loading && errorMessage">{{ errorMessage }}</div>
        <div class="feed-status" *ngIf="!loading && !errorMessage && reviews.length === 0">
          Aún no hay reseñas en tu feed. Sigue a otros oyentes o artistas para verlas aquí.
        </div>

        <app-review-card *ngFor="let review of reviews" [review]="review"></app-review-card>

        <div class="pagination" *ngIf="!loading && !errorMessage && reviews.length > 0">
          <button class="page-btn page-arrow" [disabled]="page === 0" (click)="goToPage(page - 1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
