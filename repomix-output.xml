                [title]="value + ' vistas'"
              ></div>
              <div class="chart-bar-label" [class.is-last]="last">S{{ i + 1 }}</div>
            </div>
          </div>
          <div class="detail-status" *ngIf="!stats.weeklyViews.length">
            Todavía no hay suficientes datos de vistas.
          </div>
        </div>

        <div class="dash-chart-card">
          <h3>Top ciudades</h3>
          <div class="dcc-sub">De tu audiencia</div>
          <div class="city-tags" *ngIf="stats.topCities.length">
            <span class="city-tag" *ngFor="let city of stats.topCities">{{ city }}</span>
          </div>
          <div class="detail-status" *ngIf="!stats.topCities.length">
            Todavía no hay suficientes datos de audiencia.
          </div>
        </div>
      </div>
    </ng-container>

    <!-- Reseñas recientes de tu música: no hay endpoint que las
         devuelva agrupadas por artista todavía. -->
    <div class="soon-card">
      <div class="soon-title">Reseñas recientes de tu música</div>
      <div class="soon-sub">Próximamente</div>
    </div>
  </ng-container>
</div>
