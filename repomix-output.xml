            <path
              d="M12 21s-7-4.5-9.5-9C.7 8.6 2 5 5.4 5c2 0 3.3 1.2 4 2.1.7-.9 2-2.1 4-2.1 3.4 0 4.7 3.6 2.9 7-2.5 4.5-9.5 9-9.5 9z"
