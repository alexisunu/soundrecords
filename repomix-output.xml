export interface Review {
  id: string;
  user: ReviewFeedUser;
  /**
   * ⚠️ No viene en la respuesta de GET /api/reviews/feed según el
   * contrato v1.0 (solo trae albumName/artistName/coverUrl). Sin este
   * id no se puede armar el link real a "Ver álbum" (GET
