      <div class="reviews-header">
        <div class="section-title" style="margin:0;">Reseñas de la comunidad</div>
        <span class="reviews-total" *ngIf="!loadingReviews()">{{ totalReviews() }} en total</span>
      </div>

      <div class="detail-status" *ngIf="loadingReviews()">Cargando reseñas…</div>
      <div class="detail-status" *ngIf="!loadingReviews() && reviews().length === 0">
        Aún no hay reseñas para este álbum. Sé el primero en reseñarlo.
      </div>

      <div class="reviews-list" *ngIf="!loadingReviews() && reviews().length > 0">
        <app-review-card *ngFor="let review of reviews()" [review]="review"></app-review-card>
      </div>
    </div>
  </ng-container>
</div>
