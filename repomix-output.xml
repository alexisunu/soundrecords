<!--
  VISTA 17 del mockup (MU_2.html). Se monta dentro de MainLayout, así
  que el sidebar de la app ya viene dado; este componente solo arma el
  contenido de notificaciones. Se quitó el rail de preferencias: el
  contrato no expone un GET para leerlas y el negocio decidió no
  mostrar esa opción por ahora.
-->
<div class="notif-layout">
  <!-- Lista de notificaciones -->
  <div class="notif-content">
    <div class="notif-topbar">
      <h1>Notificaciones</h1>
      <div class="nt-right">
        <span
          class="nt-mark-all"
          [class.disabled]="markingAllRead() || unreadCount() === 0"
          (click)="markAllAsRead()"
        >
          Marcar todo como leído
        </span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="notif-tabs">
      <div
        class="notif-tab"
        *ngFor="let tab of tabs"
        [class.active]="activeTab() === tab.key"
        (click)="selectTab(tab.key)"
      >
        {{ tab.label }}
        <span class="ntab-count" *ngIf="tab.key === 'all' && unreadCount() > 0">{{ unreadCount() }}</span>
      </div>
    </div>

    <div class="detail-status" *ngIf="loading()">Cargando tus notificaciones…</div>
    <div class="detail-status error" *ngIf="!loading() && error()">{{ error() }}</div>

    <ng-container *ngIf="!loading() && !error()">
      <div class="notif-list" *ngIf="groupedNotifications().length; else emptyState">
        <ng-container *ngFor="let group of groupedNotifications()">
          <div class="notif-date-group">{{ group.label }}</div>

          <div
            class="notif-item"
            *ngFor="let n of group.items"
            [class.unread]="!n.isRead"
            (click)="markAsRead(n)"
          >
            <div class="notif-item-icon">
