            <button type="button" class="btn-ghost" style="font-size:12.5px;margin-right:8px;">Cambiar foto</button>
            <button type="button" class="btn-text-danger">Eliminar</button>
          </div>
        </div>

        <form [formGroup]="profileForm" (ngSubmit)="saveProfile()">
          <div class="field">
            <label for="settings-username">Nombre de usuario</label>
            <input id="settings-username" type="text" formControlName="username" />
