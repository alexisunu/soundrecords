@media (max-width: 640px) {
  .artist-hero-content {
    padding: 20px;
  }
  .artist-hero-row {
    flex-wrap: wrap;
  }
  .artist-tabs {
    padding: 0 20px;
    gap: 16px;
  }
  .artist-main-content {
    padding: 20px 20px 60px;
  }
}
