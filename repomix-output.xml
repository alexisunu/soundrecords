import { Component, OnInit } from '@angular/core';
import { FormBuilder, FormGroup, Validators, ReactiveFormsModule } from '@angular/forms';
import { Router, RouterModule } from '@angular/router';
import { CommonModule } from '@angular/common';
import { AuthService } from '../../../core/services/auth';

@Component({
  selector: 'app-register',
  standalone: true,
  imports: [ReactiveFormsModule, CommonModule, RouterModule],
  templateUrl: './register.html',
  styleUrls: ['./register.scss'], // <- antes: './register.css'
})
export class RegisterComponent implements OnInit {
  registerForm!: FormGroup;
  loading = false;
  errorMessage = '';

  constructor(
    private fb: FormBuilder,
    private authService: AuthService,
    private router: Router,
  ) {}

  ngOnInit(): void {
    this.registerForm = this.fb.group({
      username: ['', [Validators.required, Validators.minLength(3)]],
      email: ['', [Validators.required, Validators.email]],
      password: [
        '',
        [Validators.required, Validators.pattern(/^(?=.*[A-Za-z])(?=.*\d).{8,}$/)],
      ],
    });
  }

  get registerUsername() {
    return this.registerForm.get('username');
  }

  get registerEmail() {
    return this.registerForm.get('email');
  }

  get registerPassword() {
    return this.registerForm.get('password');
  }

  onSubmitRegister(): void {
    if (this.registerForm.invalid) {
      this.registerForm.markAllAsTouched();
      return;
    }

    this.loading = true;
    this.errorMessage = '';

    this.authService.register(this.registerForm.value).subscribe({
      next: () => {
        this.loading = false;
        this.router.navigate(['/listener/feed']);
      },
      error: (err) => {
        this.loading = false;
        this.errorMessage = err.error?.message || 'Error en el registro. Nombre de usuario o email duplicados.';
      },
    });
  }
}
</file>

<file path="frontend/src/app/modules/auth/settings/settings.html">
<!--
  Esta plantilla es SOLO el contenido "main" de la vista Configuración
  (tal como en el mockup v9). La sidebar es un componente aparte que
  envolverá esta vista dentro de un layout tipo:

  <div class="app-2col">
    <app-sidebar></app-sidebar>
    <router-outlet></router-outlet>  <-- aquí se monta este componente
  </div>
-->
<main class="main">
  <div class="topbar">
    <div class="topbar-row">
      <h1>Configuración</h1>
    </div>
    <div class="settings-tabs">
      <div class="stab" [class.active]="activeTab === 'perfil'" (click)="switchTab('perfil')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.5-7 8-7s8 3 8 7"/></svg>
        Perfil
      </div>
      <div class="stab" [class.active]="activeTab === 'cuenta'" (click)="switchTab('cuenta')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
        Cuenta
      </div>
      <div class="stab" [class.active]="activeTab === 'planes'" (click)="switchTab('planes')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.7 6.6L22 9l-5 4.6L18.5 22 12 17.8 5.5 22 7 13.6 2 9l7.3-.4z"/></svg>
        Planes
      </div>
    </div>
  </div>

  <div class="settings-content">

    <!-- TAB PERFIL -->
    <div class="settings-tab-content" [style.display]="activeTab === 'perfil' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Información del perfil</h2>
            <p>Así te verán otros usuarios en la plataforma</p>
          </div>
        </div>

        <div class="avatar-row">
          <div class="avatar-big"></div>
          <div class="avatar-actions">
            <button type="button" class="btn-ghost" style="font-size:12.5px;margin-right:8px;">Cambiar foto</button>
            <button type="button" class="btn-text-danger">Eliminar</button>
          </div>
        </div>

        <form [formGroup]="profileForm" (ngSubmit)="saveProfile()">
          <div class="field">
            <label for="settings-username">Nombre de usuario</label>
            <input id="settings-username" type="text" formControlName="username" />
            <div class="hint">Visible para todos. Máx. 30 caracteres.</div>
          </div>
          <div class="field">
            <label for="settings-bio">Bio</label>
            <textarea id="settings-bio" formControlName="bio" maxlength="200"></textarea>
            <div class="char-count">{{ bioLength }} / 200</div>
          </div>
          <div class="field">
            <label for="settings-photo">URL de foto de perfil</label>
            <input id="settings-photo" type="text" formControlName="photoUrl" />
          </div>
          <div class="field">
            <label for="settings-country">País</label>
            <input id="settings-country" type="text" formControlName="country" />
          </div>
          <div class="row-actions">
            <button type="button" class="btn-ghost" (click)="discardProfileChanges()">Descartar</button>
            <button type="submit" class="btn-primary" [disabled]="profileForm.invalid">Guardar cambios</button>
          </div>
        </form>
      </div>
    </div>

    <!-- TAB CUENTA -->
    <div class="settings-tab-content" [style.display]="activeTab === 'cuenta' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Credenciales</h2>
            <p>Actualiza tu correo o contraseña</p>
          </div>
        </div>

        <form [formGroup]="credentialsForm" (ngSubmit)="saveCredentials()">
          <div class="field">
            <label for="settings-email">Correo electrónico</label>
            <input id="settings-email" type="email" formControlName="email" />
          </div>
          <div class="field">
            <label for="settings-password">Nueva contraseña</label>
            <input id="settings-password" type="password" placeholder="••••••••" formControlName="newPassword" />
            <div class="hint">Déjalo vacío para no cambiarla</div>
          </div>
          <div class="field">
            <label for="settings-password-confirm">Confirmar nueva contraseña</label>
            <input id="settings-password-confirm" type="password" placeholder="••••••••" formControlName="confirmPassword" />
          </div>
          <div class="hint error" *ngIf="credentialsError">{{ credentialsError }}</div>
          <div class="row-actions">
            <button type="submit" class="btn-primary" [disabled]="credentialsForm.invalid">Actualizar credenciales</button>
          </div>
        </form>
      </div>

      <div class="section">
        <div class="section-head">
          <div>
            <h2>Zona de peligro</h2>
            <p>Estas acciones son permanentes y no se pueden deshacer</p>
          </div>
        </div>
        <button type="button" class="btn-danger" (click)="onDeleteAccount()">Eliminar mi cuenta</button>
      </div>
    </div>

    <!-- TAB PLANES -->
    <div class="settings-tab-content" [style.display]="activeTab === 'planes' ? 'block' : 'none'">
      <div style="margin-bottom:16px;">
        <div class="plans-title">Elige tu plan</div>
        <div class="plans-sub">Actualmente en <strong>{{ user?.isPremium ? 'Plan Premium' : 'Plan Gratis' }}</strong></div>
      </div>

      <div class="plans-grid">
        <div class="plan-card">
          <div class="plan-name">Gratis</div>
          <div class="plan-price">$0 <span>/ mes</span></div>
          <ul class="plan-features">
            <li>Reseñas ilimitadas</li>
            <li>Feed personalizado</li>
            <li>Misiones diarias</li>
          </ul>
          <button type="button" class="plan-btn free" [disabled]="!user?.isPremium">
            {{ user?.isPremium ? 'Volver a Gratis' : 'Plan actual' }}
          </button>
        </div>

        <div class="plan-card popular">
          <div class="plan-popular-badge">⭐ Más popular</div>
          <div class="plan-name">Oyente Premium</div>
          <div class="plan-price">$3.99 <span>/ mes</span></div>
          <ul class="plan-features">
            <li>Todo lo del plan Gratis</li>
            <li>Sin anuncios</li>
            <li>Estadísticas avanzadas</li>
            <li>Vinculación Spotify</li>
          </ul>
          <button type="button" class="plan-btn premium" (click)="selectPlan('Oyente Premium')">Suscribirme</button>
        </div>

        <div class="plan-card">
          <div class="plan-name">Artista Premium</div>
          <div class="plan-price">$12 <span>/ mes</span></div>
          <ul class="plan-features">
            <li>Todo lo de Oyente Premium</li>
            <li>Dashboard de artista</li>
            <li>Analíticas avanzadas</li>
            <li>Boost de visibilidad</li>
            <li>Perfil verificado</li>
          </ul>
          <button type="button" class="plan-btn artist" (click)="selectPlan('Artista Premium')">Suscribirme</button>
        </div>
      </div>
    </div>

  </div>
</main>
</file>

<file path="frontend/src/app/modules/auth/settings/settings.scss">
:host {
  --bg: #0a1128;
  --accent: #17d1e8;
  --accent-2: #9b5de5;
  --text: #ffffff;
  --text-secondary: #8f9cae;
  --card: #131c38;
  --card-border: rgba(143, 156, 174, 0.14);
  --accent-glow: rgba(23, 209, 232, 0.25);
  --danger: #f15f6c;
  --success: #2ee89a;

  display: block;
  font-family: 'Inter', sans-serif;
  color: var(--text);
}

h1, h2, h3 { font-family: 'Space Grotesk', sans-serif; }

/* ===== MAIN (columna que ocupa esta vista dentro del futuro app-2col) ===== */
.main {
  min-height: 100vh;
  background: radial-gradient(circle at 85% -5%, rgba(23, 209, 232, 0.08), transparent 45%), var(--bg);
}

/* ===== TOPBAR ===== */
.topbar {
  position: sticky;
  top: 0;
  z-index: 5;
  background: rgba(10, 17, 40, 0.85);
  backdrop-filter: blur(10px);
  padding: 18px 28px;
  border-bottom: 1px solid var(--card-border);
}
.topbar-row { display: flex; align-items: center; gap: 14px; }
.topbar h1 { font-size: 20px; font-weight: 700; }

.settings-tabs {
  display: flex;
  gap: 26px;
  margin-top: 16px;
  overflow-x: auto;
}
.stab {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--text-secondary);
  padding-bottom: 14px;
  border-bottom: 2px solid transparent;
  display: flex;
  align-items: center;
  gap: 7px;
  cursor: pointer;
  white-space: nowrap;

  svg { width: 15px; height: 15px; }

  &.active {
    color: var(--text);
    border-color: var(--accent);
    svg { color: var(--accent); }
  }
}

/* ===== CONTENIDO ===== */
.settings-content {
  padding: 30px 36px 70px;
  max-width: 680px;
}

.section {
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 22px;
}
.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 20px;

  h2 { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
  p { font-size: 12.5px; color: var(--text-secondary); line-height: 1.5; }
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 22px;
}
.avatar-big {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3a4a78, #1b2750);
  border: 2px solid rgba(23, 209, 232, 0.4);
  flex-shrink: 0;
}
.avatar-actions { display: flex; align-items: center; }

/* ===== CAMPOS ===== */
.field { margin-bottom: 18px; }
.field label {
  display: block;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 7px;
}
.field input, .field textarea, .field select {
  width: 100%;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--card-border);
  border-radius: 10px;
  padding: 11px 14px;
  font-size: 13.5px;
  color: var(--text);
  font-family: inherit;

  &:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }
}
.field textarea { resize: none; height: 90px; }
.field .hint { font-size: 11.5px; color: var(--text-secondary); margin-top: 6px; }
.field .hint.error, .hint.error { color: var(--danger); }
.char-count { font-size: 11px; color: var(--text-secondary); text-align: right; margin-top: 5px; }

.row-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 6px;
}

/* ===== BOTONES ===== */
.btn-primary {
  background: var(--accent);
  color: var(--bg);
  font-weight: 700;
  font-size: 13px;
  padding: 10px 20px;
  border-radius: 10px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: transform .15s;
  &:hover { transform: translateY(-1px); }
  &:disabled { opacity: .5; cursor: not-allowed; }
}
.btn-ghost {
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
  border: 1px solid rgba(23, 209, 232, 0.4);
  border-radius: 10px;
  padding: 9px 18px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: transparent;
  &:hover { background: rgba(23, 209, 232, 0.07); }
}
.btn-danger {
  background: rgba(241, 95, 108, 0.12);
  color: var(--danger);
  border: 1px solid rgba(241, 95, 108, 0.3);
  font-weight: 600;
  font-size: 13px;
  padding: 9px 18px;
  border-radius: 10px;
}
.btn-text-danger {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--text-secondary);
  background: none;
  border: none;
  &:hover { color: var(--danger); }
}

/* ===== PLANES ===== */
.plans-title {
  font-size: 22px;
  font-weight: 700;
  font-family: 'Space Grotesk', sans-serif;
  margin-bottom: 6px;
}
.plans-sub { font-size: 13.5px; color: var(--text-secondary); }
.plans-sub strong { color: var(--text); }

.plans-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-top: 20px;
}
.plan-card {
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 16px;
  padding: 22px 18px;
  text-align: center;
  position: relative;
  transition: border-color .15s;

  &.popular {
    border-color: rgba(23, 209, 232, 0.5);
    box-shadow: 0 0 30px rgba(23, 209, 232, 0.1);
  }
}
.plan-popular-badge {
  position: absolute;
  top: -10px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--accent);
  color: var(--bg);
  font-size: 10.5px;
  font-weight: 700;
  padding: 3px 12px;
  border-radius: 20px;
}
.plan-name { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.plan-price {
  font-size: 28px;
  font-weight: 700;
  font-family: 'Space Grotesk', sans-serif;
  color: var(--accent);
  margin-bottom: 4px;
  span { font-size: 13px; color: var(--text-secondary); }
}
.plan-features {
  list-style: none;
  text-align: left;
  margin: 16px 0;
  display: flex;
  flex-direction: column;
  gap: 8px;

  li {
    font-size: 12.5px;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 7px;
    &::before { content: "✓"; color: var(--accent); font-weight: 700; flex-shrink: 0; }
  }
}
.plan-btn {
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  margin-top: 4px;
  &:disabled { opacity: .6; cursor: not-allowed; }

  &.free { background: rgba(143, 156, 174, 0.1); color: var(--text-secondary); }
  &.premium { background: var(--accent); color: var(--bg); }
  &.artist { background: rgba(155, 93, 229, 0.2); color: #c9a0ff; border: 1px solid rgba(155, 93, 229, 0.4); }
}

@media (max-width: 720px) {
  .plans-grid { grid-template-columns: 1fr; }
  .settings-content { padding: 24px 18px 60px; }
}
</file>

<file path="frontend/src/app/modules/gamification/missions/missions.html">
<!--
  VISTA 12 del mockup (MU_2.html). Se monta dentro de MainLayout.
-->
<div class="topbar">
  <div class="topbar-row">
    <h1>Misiones y progreso</h1>
  </div>
</div>

<div class="missions-content">
  <div class="page-status" *ngIf="loadingMe()">Cargando tu progreso…</div>
  <div class="page-status error" *ngIf="!loadingMe() && errorMe()">{{ errorMe() }}</div>

  <ng-container *ngIf="!loadingMe() && !errorMe() && me() as m">
    <!-- XP Hero -->
    <div class="xp-hero">
      <div class="xp-ring">
        <svg viewBox="0 0 80 80">
          <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(143,156,174,0.12)" stroke-width="8" />
          <circle
            cx="40"
            cy="40"
            r="34"
            fill="none"
            stroke="url(#xpGrad)"
            stroke-width="8"
            [attr.stroke-dasharray]="ringCircumference"
            [attr.stroke-dashoffset]="ringDashoffset()"
            stroke-linecap="round"
          />
          <defs>
            <linearGradient id="xpGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#17D1E8" />
              <stop offset="100%" stop-color="#9B5DE5" />
            </linearGradient>
          </defs>
        </svg>
        <div class="xp-ring-num">
          <div class="lvl">{{ levelProgressPct() }}%</div>
          <div class="lbl">NIV</div>
        </div>
      </div>
      <div class="xp-info">
        <div class="xp-title">{{ m.level }}</div>
        <div class="xp-sub">Estás a <strong>{{ m.pointsToNextLevel }} pts</strong> del siguiente nivel</div>
        <div class="xp-bar-wrap">
          <div class="xp-bar"><div class="xp-bar-fill" [style.width.%]="levelProgressPct()"></div></div>
          <div class="xp-bar-label">{{ m.points }} / {{ m.points + m.pointsToNextLevel }} pts</div>
        </div>
      </div>
      <div class="xp-stats">
        <div class="xp-stat">
          <div class="val">{{ loadingBadges() ? '—' : ownedBadges().length }}</div>
          <div class="key">Insignias</div>
        </div>
      </div>
    </div>

    <!-- Nota: el mockup incluía una "Racha semanal" con calendario
         Lun–Dom, pero el contrato de la API no expone ningún dato de
         racha (streak) en /api/missions/me ni en ningún otro endpoint.
         La quitamos en vez de inventar datos falsos; si el backend
         llega a exponerlo, se agrega aquí. -->

    <!-- Misiones diarias -->
    <div class="section-title" *ngIf="dailyMissions().length">Misiones diarias</div>
    <div class="missions-grid" *ngIf="dailyMissions().length">
      <div class="mission-card" *ngFor="let mission of dailyMissions()" [class.completed]="mission.completed">
        <div class="mission-card-head">
          <div class="mission-card-icon" [class.green]="mission.completed">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 20h9M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4L16.5 3.5z" />
            </svg>
          </div>
          <div class="mission-card-meta">
            <div class="tag" [style.color]="mission.completed ? 'var(--success)' : null">
              {{ mission.completed ? 'Completada ✓' : 'Diaria' }}
            </div>
            <h3>{{ mission.name }}</h3>
            <p *ngIf="mission.description">{{ mission.description }}</p>
          </div>
          <div class="mission-reward" *ngIf="!mission.completed">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2l3 6.5 7 .8-5.2 4.9 1.4 7-6.2-3.6-6.2 3.6 1.4-7L2 9.3l7-.8z" />
            </svg>
            +{{ mission.rewardPoints }} pts
          </div>
          <div class="mission-complete-check" *ngIf="mission.completed">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </div>
        </div>

        <div class="mc-bar-wrap" *ngIf="progressPct(mission.progress) as pct">
          <div class="mc-bar"><span [style.width.%]="pct" [style.background]="mission.completed ? 'var(--success)' : null"></span></div>
          <div class="mc-bar-label">
            <span [style.color]="mission.completed ? 'var(--success)' : null">{{ mission.progress }}</span>
            <strong [style.color]="mission.completed ? 'var(--success)' : null">{{ pct }}%</strong>
          </div>
        </div>
      </div>
    </div>

    <!-- Misiones de logro -->
    <div class="section-title" *ngIf="achievementMissions().length">Logros</div>
    <div class="missions-grid" *ngIf="achievementMissions().length">
      <div class="mission-card" *ngFor="let mission of achievementMissions()" [class.completed]="mission.completed">
        <div class="mission-card-head">
          <div class="mission-card-icon purple" [class.green]="mission.completed">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"
              />
            </svg>
          </div>
          <div class="mission-card-meta">
            <div class="tag" [style.color]="mission.completed ? 'var(--success)' : '#c9a0ff'">
              {{ mission.completed ? 'Completada ✓' : 'Logro' }}
            </div>
            <h3>{{ mission.name }}</h3>
            <p *ngIf="mission.description">{{ mission.description }}</p>
          </div>
          <div class="mission-reward" style="color: #c9a0ff" *ngIf="!mission.completed">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2l3 6.5 7 .8-5.2 4.9 1.4 7-6.2-3.6-6.2 3.6 1.4-7L2 9.3l7-.8z" />
            </svg>
            +{{ mission.rewardPoints }} pts
          </div>
          <div class="mission-complete-check" *ngIf="mission.completed">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </div>
        </div>

        <div class="mc-bar-wrap" *ngIf="progressPct(mission.progress) as pct">
          <div class="mc-bar"><span [style.width.%]="pct" [style.background]="mission.completed ? 'var(--success)' : '#9B5DE5'"></span></div>
          <div class="mc-bar-label">
            <span [style.color]="mission.completed ? 'var(--success)' : null">{{ mission.progress }}</span>
            <strong [style.color]="mission.completed ? 'var(--success)' : null">{{ pct }}%</strong>
          </div>
        </div>
      </div>
    </div>

    <div class="page-status" *ngIf="!dailyMissions().length && !achievementMissions().length">
      No tienes misiones activas por ahora.
    </div>

    <!-- Insignias conseguidas -->
    <div class="badges-section-title">
      Insignias conseguidas
      <span *ngIf="!loadingBadges()">{{ ownedBadges().length }} desbloqueadas</span>
    </div>

    <div class="page-status" *ngIf="loadingBadges()">Cargando insignias…</div>
    <div class="page-status error" *ngIf="!loadingBadges() && errorBadges()">{{ errorBadges() }}</div>
    <div class="page-status" *ngIf="!loadingBadges() && !errorBadges() && ownedBadges().length === 0">
      Todavía no tienes insignias. Consíguelas completando misiones o cómpralas en la tienda.
    </div>

    <div class="badges-showcase" *ngIf="!loadingBadges() && ownedBadges().length > 0">
      <div class="badge-chip" *ngFor="let badge of ownedBadges()">
        <div class="badge-icon-wrap">
          <img *ngIf="badge.imageUrl" [src]="badge.imageUrl" [alt]="badge.name" />
          <svg *ngIf="!badge.imageUrl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2l2.7 6.6L22 9l-5 4.6L18.5 22 12 17.8 5.5 22 7 13.6 2 9l7.3-.4z" />
          </svg>
        </div>
        <div class="badge-chip-info">
