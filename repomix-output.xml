/* ========================================================
   SOUNDRECORDS — LOGIN / REGISTRO
   Tokens tomados del mockup oficial (paleta corporativa)
   ======================================================== */

:host {
  --bg: #0a1128;
  --accent: #17d1e8;
  --accent-2: #9b5de5;
  --text: #ffffff;
  --text-secondary: #8f9cae;
  --card: #131c38;
  --card-border: rgba(143, 156, 174, 0.14);
  --accent-glow: rgba(23, 209, 232, 0.25);
  --danger: #f15f6c;
  --success: #2ee89a;

  display: block;
  font-family: 'Inter', sans-serif;
  color: var(--text);
}

/* ===== CONTENEDOR CENTRADO ===== */
.app-auth {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
  background: radial-gradient(
      circle at 50% 30%,
      rgba(23, 209, 232, 0.07),
      transparent 60%
    ),
    var(--bg);
}

/* ===== TARJETA DE AUTENTICACIÓN ===== */
.auth-box {
  width: 100%;
  max-width: 440px;
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 20px;
  padding: 36px;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
}

/* ===== LOGO ===== */
.auth-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  justify-content: center;
  margin-bottom: 28px;
}

.auth-logo-mark {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: radial-gradient(
      circle at 50% 50%,
      var(--bg) 0 28%,
      transparent 29%
    ),
    conic-gradient(from 180deg, var(--accent), #0a6e7a 40%, var(--accent));
  box-shadow: 0 0 20px var(--accent-glow);
  flex-shrink: 0;
}

.auth-logo-text {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 20px;
  font-weight: 700;

  span {
    color: var(--accent);
  }
}

/* ===== TABS (Iniciar sesión / Crear cuenta) ===== */
.auth-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  padding: 4px;
  margin-bottom: 26px;
}

.auth-tab {
  flex: 1;
  padding: 9px;
  border-radius: 9px;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: center;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  user-select: none;

  &.active {
    background: var(--accent);
    color: var(--bg);
  }
}

/* ===== TÍTULOS ===== */
.auth-title {
