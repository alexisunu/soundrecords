/* ===== Layout: main + rail, como feed.scss ===== */
.store-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  max-width: 1264px;
  margin: 0 auto;
  min-height: 100vh;
}
@media (max-width: 960px) {
  .store-layout {
    grid-template-columns: 1fr;
