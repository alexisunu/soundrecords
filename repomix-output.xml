.artist-stat-card .asc-key {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 3px;
  font-weight: 500;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  margin-bottom: 16px;
}

