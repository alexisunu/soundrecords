}
.avatar-sm {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3a4a78, #1b2750);
  flex-shrink: 0;
  border: 1.5px solid rgba(23, 209, 232, 0.4);
}
/* ===== FEED ===== */
.feed {
  padding: 22px 28px 60px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.feed-status {
  text-align: center;
  font-size: 13.5px;
  color: var(--text-secondary);
  padding: 24px 0;
}
.feed-status.error {
  color: var(--danger);
}
.suggest-banner {
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 16px;
  padding: 16px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
}
.suggest-banner .ic {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(23, 209, 232, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.suggest-banner .ic svg {
  width: 20px;
  height: 20px;
  color: var(--accent);
}
.suggest-banner .txt {
  flex: 1;
}
.suggest-banner .txt strong {
  font-size: 14px;
}
.suggest-banner .txt p {
  font-size: 12.5px;
  color: var(--text-secondary);
  margin-top: 3px;
}
.suggest-banner .cta {
  background: var(--accent);
  color: var(--bg);
  font-weight: 700;
  font-size: 12.5px;
  padding: 9px 16px;
  border-radius: 10px;
  white-space: nowrap;
  flex-shrink: 0;
  border: none;
  cursor: pointer;
}
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 8px 0 20px;
}
.page-btn {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--card);
  border: 1px solid var(--card-border);
  display: flex;
  align-items: center;
  justify-content: center;
}
.page-btn.active {
  background: var(--accent);
  color: var(--bg);
  border-color: var(--accent);
}
.page-btn:disabled {
  opacity: 0.4;
  cursor: default;
}
.page-btn svg {
  width: 16px;
  height: 16px;
}

/* ===== RIGHT RAIL ===== */
.rail {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  border-left: 1px solid var(--card-border);
}
.promo-banner {
  display: block;
  border-radius: 14px;
  overflow: hidden;
  line-height: 0;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.promo-banner:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(255, 90, 46, 0.2);
}
.promo-banner img {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 280 / 360;
  object-fit: cover;
  border-radius: 14px;
}
