    });
    expect(component.registerForm.valid).toBeFalsy();
  });

  it('registerForm debería ser válido con datos correctos', () => {
    component.registerForm.setValue({
      username: 'usuario',
      email: 'test@correo.com',
      password: 'abcd1234',
    });
    expect(component.registerForm.valid).toBeTruthy();
  });
});
