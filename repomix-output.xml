        Privacidad
      </div>
      <div class="stab" [class.active]="activeTab === 'planes'" (click)="switchTab('planes')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.7 6.6L22 9l-5 4.6L18.5 22 12 17.8 5.5 22 7 13.6 2 9l7.3-.4z"/></svg>
        Planes
      </div>
    </div>
  </div>

  <div class="settings-content">

    <!-- TAB PERFIL -->
    <div class="settings-tab-content" [style.display]="activeTab === 'perfil' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Información del perfil</h2>
            <p>Así te verán otros usuarios en la plataforma</p>
          </div>
        </div>

        <div class="avatar-row">
          <div class="avatar-big"></div>
