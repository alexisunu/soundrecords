<file path="frontend/src/app/modules/auth/register/register.ts">
import { Component, OnInit } from '@angular/core';
import { FormBuilder, FormGroup, Validators, ReactiveFormsModule } from '@angular/forms';
import { Router, RouterModule } from '@angular/router';
import { CommonModule } from '@angular/common';
import { AuthService } from '../../../core/services/auth';

@Component({
  selector: 'app-register',
  standalone: true,
  imports: [ReactiveFormsModule, CommonModule, RouterModule],
  templateUrl: './register.html',
  styleUrls: ['./register.scss'], // <- antes: './register.css'
})
export class RegisterComponent implements OnInit {
  registerForm!: FormGroup;
  loading = false;
  errorMessage = '';

  constructor(
    private fb: FormBuilder,
    private authService: AuthService,
    private router: Router,
  ) {}

  ngOnInit(): void {
    this.registerForm = this.fb.group({
      username: ['', [Validators.required, Validators.minLength(3)]],
      email: ['', [Validators.required, Validators.email]],
      password: [
        '',
        [Validators.required, Validators.pattern(/^(?=.*[A-Za-z])(?=.*\d).{8,}$/)],
      ],
    });
  }

  get registerUsername() {
    return this.registerForm.get('username');
  }

  get registerEmail() {
    return this.registerForm.get('email');
  }

  get registerPassword() {
    return this.registerForm.get('password');
  }

  onSubmitRegister(): void {
    if (this.registerForm.invalid) {
      this.registerForm.markAllAsTouched();
      return;
    }

    this.loading = true;
    this.errorMessage = '';

    this.authService.register(this.registerForm.value).subscribe({
      next: () => {
        this.loading = false;
        this.router.navigate(['/listener/feed']);
      },
      error: (err) => {
        this.loading = false;
        this.errorMessage = err.error?.message || 'Error en el registro. Nombre de usuario o email duplicados.';
      },
    });
  }

  registerWithSpotify(): void {
    // TODO: conectar con POST /api/spotify/connect cuando esté disponible
  }
}
</file>

<file path="frontend/src/app/modules/auth/settings/settings.html">
<!--
  Esta plantilla es SOLO el contenido "main" de la vista Configuración
  (tal como en el mockup v9). La sidebar es un componente aparte que
  envolverá esta vista dentro de un layout tipo:

  <div class="app-2col">
    <app-sidebar></app-sidebar>
    <router-outlet></router-outlet>  <-- aquí se monta este componente
  </div>
-->
<main class="main">
  <div class="topbar">
    <div class="topbar-row">
      <h1>Configuración</h1>
    </div>
    <div class="settings-tabs">
      <div class="stab" [class.active]="activeTab === 'perfil'" (click)="switchTab('perfil')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.5-7 8-7s8 3 8 7"/></svg>
        Perfil
      </div>
      <div class="stab" [class.active]="activeTab === 'cuenta'" (click)="switchTab('cuenta')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
        Cuenta
      </div>
      <div class="stab" [class.active]="activeTab === 'spotify'" (click)="switchTab('spotify')">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.373 0 12s5.37 12 12 12 12-5.373 12-12S18.63 0 12 0z"/></svg>
        Spotify
      </div>
      <div class="stab" [class.active]="activeTab === 'privacidad'" (click)="switchTab('privacidad')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-8 10-8 10S4 17 4 12V6z"/></svg>
        Privacidad
      </div>
      <div class="stab" [class.active]="activeTab === 'planes'" (click)="switchTab('planes')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.7 6.6L22 9l-5 4.6L18.5 22 12 17.8 5.5 22 7 13.6 2 9l7.3-.4z"/></svg>
        Planes
      </div>
    </div>
  </div>

  <div class="settings-content">

    <!-- TAB PERFIL -->
    <div class="settings-tab-content" [style.display]="activeTab === 'perfil' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Información del perfil</h2>
            <p>Así te verán otros usuarios en la plataforma</p>
          </div>
        </div>

        <div class="avatar-row">
          <div class="avatar-big"></div>
          <div class="avatar-actions">
            <button type="button" class="btn-ghost" style="font-size:12.5px;margin-right:8px;">Cambiar foto</button>
            <button type="button" class="btn-text-danger">Eliminar</button>
          </div>
        </div>

        <form [formGroup]="profileForm" (ngSubmit)="saveProfile()">
          <div class="field">
            <label for="settings-username">Nombre de usuario</label>
            <input id="settings-username" type="text" formControlName="username" />
            <div class="hint">Visible para todos. Máx. 30 caracteres.</div>
          </div>
          <div class="field">
            <label for="settings-bio">Bio</label>
            <textarea id="settings-bio" formControlName="bio" maxlength="200"></textarea>
            <div class="char-count">{{ bioLength }} / 200</div>
          </div>
          <div class="field">
            <label for="settings-photo">URL de foto de perfil</label>
            <input id="settings-photo" type="text" formControlName="photoUrl" />
          </div>
          <div class="field">
            <label for="settings-country">País</label>
            <input id="settings-country" type="text" formControlName="country" />
          </div>
          <div class="row-actions">
            <button type="button" class="btn-ghost" (click)="discardProfileChanges()">Descartar</button>
            <button type="submit" class="btn-primary" [disabled]="profileForm.invalid">Guardar cambios</button>
          </div>
        </form>
      </div>
    </div>

    <!-- TAB CUENTA -->
    <div class="settings-tab-content" [style.display]="activeTab === 'cuenta' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Credenciales</h2>
            <p>Actualiza tu correo o contraseña</p>
          </div>
        </div>

        <form [formGroup]="credentialsForm" (ngSubmit)="saveCredentials()">
          <div class="field">
            <label for="settings-email">Correo electrónico</label>
            <input id="settings-email" type="email" formControlName="email" />
          </div>
          <div class="field">
            <label for="settings-password">Nueva contraseña</label>
            <input id="settings-password" type="password" placeholder="••••••••" formControlName="newPassword" />
            <div class="hint">Déjalo vacío para no cambiarla</div>
          </div>
          <div class="field">
            <label for="settings-password-confirm">Confirmar nueva contraseña</label>
            <input id="settings-password-confirm" type="password" placeholder="••••••••" formControlName="confirmPassword" />
          </div>
          <div class="hint error" *ngIf="credentialsError">{{ credentialsError }}</div>
          <div class="row-actions">
            <button type="submit" class="btn-primary" [disabled]="credentialsForm.invalid">Actualizar credenciales</button>
          </div>
        </form>
      </div>

      <div class="section">
        <div class="section-head">
          <div>
            <h2>Zona de peligro</h2>
            <p>Estas acciones son permanentes y no se pueden deshacer</p>
          </div>
        </div>
        <button type="button" class="btn-danger" (click)="onDeleteAccount()">Eliminar mi cuenta</button>
      </div>
    </div>

    <!-- TAB SPOTIFY -->
    <div class="settings-tab-content" [style.display]="activeTab === 'spotify' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Vinculación con Spotify</h2>
            <p>Conecta tu cuenta para importar tu historial de álbumes escuchados</p>
          </div>
        </div>

        <div class="spotify-connected" *ngIf="user?.spotifyLinked; else notLinked">
          <div class="sp-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M12 0C5.37 0 0 5.373 0 12s5.37 12 12 12 12-5.373 12-12S18.63 0 12 0zm5.44 17.32c-.213.34-.665.45-1.005.237-2.75-1.682-6.213-2.06-10.29-1.128-.39.09-.78-.15-.87-.54-.09-.39.15-.78.54-.87 4.46-1.02 8.29-.583 11.38 1.3.34.213.45.665.247 1.001z"/></svg>
          </div>
          <div class="sp-info">
            <div class="sp-name">{{ user?.username }} Spotify</div>
            <div class="sp-status">✓ Conectado</div>
          </div>
          <button type="button" class="btn-danger" style="padding:7px 14px;font-size:12px;" (click)="disconnectSpotify()">Desvincular</button>
        </div>

        <ng-template #notLinked>
          <button type="button" class="spotify-btn" (click)="disconnectSpotify()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.373 0 12s5.37 12 12 12 12-5.373 12-12S18.63 0 12 0zm5.44 17.32c-.213.34-.665.45-1.005.237-2.75-1.682-6.213-2.06-10.29-1.128-.39.09-.78-.15-.87-.54-.09-.39.15-.78.54-.87 4.46-1.02 8.29-.583 11.38 1.3.34.213.45.665.247 1.001z"/></svg>
            Conectar con Spotify
          </button>
        </ng-template>
      </div>
    </div>

    <!-- TAB PRIVACIDAD -->
    <div class="settings-tab-content" [style.display]="activeTab === 'privacidad' ? 'block' : 'none'">
      <div class="section">
        <div class="section-head">
          <div>
            <h2>Privacidad del perfil</h2>
            <p>Controla quién puede ver tu actividad</p>
          </div>
        </div>

        <form [formGroup]="privacyForm" (ngSubmit)="savePrivacy()">
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Perfil público</div>
              <div class="toggle-sub">Cualquiera puede ver tu perfil y reseñas</div>
            </div>
            <label class="toggle" [class.on]="privacyForm.get('publicProfile')?.value">
              <input type="checkbox" formControlName="publicProfile" style="display:none;" />
            </label>
          </div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Mostrar mis listas</div>
              <div class="toggle-sub">Tus colecciones serán visibles para todos</div>
            </div>
            <label class="toggle" [class.on]="privacyForm.get('showLists')?.value">
              <input type="checkbox" formControlName="showLists" style="display:none;" />
            </label>
          </div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Mostrar mis likes</div>
              <div class="toggle-sub">Oculta las reseñas a las que has dado like</div>
            </div>
            <label class="toggle" [class.on]="privacyForm.get('showLikes')?.value">
              <input type="checkbox" formControlName="showLikes" style="display:none;" />
            </label>
          </div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Notificaciones por email</div>
              <div class="toggle-sub">Recibe avisos de likes, seguidores y misiones</div>
            </div>
            <label class="toggle" [class.on]="privacyForm.get('emailNotifications')?.value">
              <input type="checkbox" formControlName="emailNotifications" style="display:none;" />
            </label>
          </div>
          <div class="row-actions">
            <button type="submit" class="btn-primary">Guardar preferencias</button>
          </div>
        </form>
      </div>
    </div>

    <!-- TAB PLANES -->
    <div class="settings-tab-content" [style.display]="activeTab === 'planes' ? 'block' : 'none'">
      <div style="margin-bottom:16px;">
        <div class="plans-title">Elige tu plan</div>
        <div class="plans-sub">Actualmente en <strong>{{ user?.isPremium ? 'Plan Premium' : 'Plan Gratis' }}</strong></div>
      </div>

      <div class="plans-grid">
        <div class="plan-card">
          <div class="plan-name">Gratis</div>
          <div class="plan-price">$0 <span>/ mes</span></div>
          <ul class="plan-features">
            <li>Reseñas ilimitadas</li>
            <li>Feed personalizado</li>
            <li>Misiones diarias</li>
          </ul>
          <button type="button" class="plan-btn free" [disabled]="!user?.isPremium">
            {{ user?.isPremium ? 'Volver a Gratis' : 'Plan actual' }}
          </button>
        </div>

        <div class="plan-card popular">
          <div class="plan-popular-badge">⭐ Más popular</div>
          <div class="plan-name">Oyente Premium</div>
          <div class="plan-price">$4.99 <span>/ mes</span></div>
          <ul class="plan-features">
            <li>Todo lo del plan Gratis</li>
            <li>Sin anuncios</li>
            <li>Estadísticas avanzadas</li>
            <li>Vinculación Spotify</li>
          </ul>
          <button type="button" class="plan-btn premium" (click)="selectPlan('Oyente Premium')">Suscribirme</button>
        </div>

        <div class="plan-card">
          <div class="plan-name">Artista Premium</div>
          <div class="plan-price">$9.99 <span>/ mes</span></div>
          <ul class="plan-features">
            <li>Todo lo de Oyente Premium</li>
            <li>Dashboard de artista</li>
            <li>Analíticas avanzadas</li>
            <li>Boost de visibilidad</li>
            <li>Perfil verificado</li>
          </ul>
          <button type="button" class="plan-btn artist" (click)="selectPlan('Artista Premium')">Suscribirme</button>
        </div>
      </div>
    </div>

  </div>
</main>
