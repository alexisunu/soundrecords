<file path="frontend/src/app/modules/listener/my-profile/my-profile.scss">
:host {
  --bg: #0a1128;
  --accent: #17d1e8;
  --accent-2: #9b5de5;
  --text: #ffffff;
  --text-secondary: #8f9cae;
  --card: #131c38;
  --card-border: rgba(143, 156, 174, 0.14);
  --accent-glow: rgba(23, 209, 232, 0.25);
  --danger: #f15f6c;
  --success: #2ee89a;

  display: block;
  font-family: 'Inter', sans-serif;
  color: var(--text);
}

h1, h2, h3 { font-family: 'Space Grotesk', sans-serif; }

/* ===== MAIN (columna que ocupa esta vista dentro del futuro app-2col) ===== */
.main {
  min-height: 100vh;
  background: radial-gradient(circle at 85% -5%, rgba(23, 209, 232, 0.08), transparent 45%), var(--bg);
}

/* ===== TOPBAR ===== */
.topbar {
  position: sticky;
  top: 0;
  z-index: 5;
  background: rgba(10, 17, 40, 0.85);
  backdrop-filter: blur(10px);
  padding: 18px 28px;
  border-bottom: 1px solid var(--card-border);
}
.topbar-row { display: flex; align-items: center; gap: 14px; }
.topbar h1 { font-size: 20px; font-weight: 700; flex-shrink: 0; }

.btn-ghost {
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
  border: 1px solid rgba(23, 209, 232, 0.4);
  border-radius: 10px;
  padding: 9px 18px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: transparent;
  &:hover { background: rgba(23, 209, 232, 0.07); }
}

/* ===== PERFIL ===== */
.profile-content { padding: 32px 28px 60px; }
.profile-header { display: flex; align-items: flex-start; gap: 24px; margin-bottom: 28px; }
.avatar-xl {
  width: 96px;
  height: 96px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3a4a78, #1b2750);
  flex-shrink: 0;
  border: 3px solid rgba(23, 209, 232, 0.5);
  box-shadow: 0 0 24px rgba(23, 209, 232, 0.2);
}
.profile-info h2 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
.profile-bio { font-size: 13.5px; color: var(--text-secondary); margin-bottom: 12px; line-height: 1.5; }
.profile-stats { display: flex; gap: 20px; margin-bottom: 14px; }
.stats-error {
  font-size: 12px;
  color: var(--danger);
  margin-top: -6px;
  margin-bottom: 14px;
}
.stats-error a {
  color: var(--accent);
  font-weight: 600;
  cursor: pointer;
  margin-left: 4px;
}
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 2px; }
.stat-num { font-size: 18px; font-weight: 700; font-family: 'Space Grotesk', sans-serif; }
.stat-label { font-size: 11.5px; color: var(--text-secondary); }

.level-badge {
  display: flex;
  align-items: center;
  gap: 10px;
  max-width: 340px;
}
.level-badge .lv { font-size: 12.5px; font-weight: 700; color: var(--accent); }
.level-bar-wrap { height: 6px; background: rgba(143, 156, 174, 0.15); border-radius: 4px; flex: 1; overflow: hidden; }
.level-bar { height: 100%; background: var(--accent); border-radius: 4px; }
.pts { font-size: 11.5px; color: var(--text-secondary); }

/* ===== BADGES ===== */
.badges-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 12px;
  padding: 12px 16px;
  min-width: 76px;
}
.badge-icon { font-size: 24px; display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; }
.badge-icon img { width: 28px; height: 28px; object-fit: contain; border-radius: 6px; }
.badge-name { font-size: 11px; color: var(--text-secondary); font-weight: 600; text-align: center; }
.badge-item.skeleton {
  min-height: 62px;
  min-width: 76px;
  background: linear-gradient(90deg, var(--card) 25%, rgba(143, 156, 174, 0.12) 50%, var(--card) 75%);
  background-size: 200% 100%;
  animation: badge-shimmer 1.3s infinite;
  border-color: transparent;
}
@keyframes badge-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.badges-status {
  font-size: 12.5px;
  color: var(--text-secondary);
  margin-bottom: 28px;
}
.badges-status a { color: var(--accent); font-weight: 600; }
.badges-status.error { color: var(--danger); }

/* ===== TABS ===== */
.profile-tabs { display: flex; gap: 18px; border-bottom: 1px solid var(--card-border); margin-bottom: 22px; }
.profile-tab {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--text-secondary);
  padding-bottom: 12px;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  &.active { color: var(--text); border-color: var(--accent); }
}

/* ===== REVIEW CARD ===== */
.review-card { background: var(--card); border: 1px solid var(--card-border); border-radius: 16px; padding: 18px; transition: border-color .15s; }
.review-card:hover { border-color: rgba(23, 209, 232, 0.35); }
.review-head { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.review-head .meta { flex: 1; min-width: 0; }
.review-head .uname { font-size: 13.5px; font-weight: 600; }
.review-head .when { font-size: 12px; color: var(--text-secondary); }
.review-body { display: flex; gap: 16px; }

.avatar-sm { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, #3a4a78, #1b2750); flex-shrink: 0; border: 1.5px solid rgba(23, 209, 232, 0.4); }

.album-art-wrap { position: relative; flex-shrink: 0; width: 88px; height: 88px; }
.vinyl-peek {
  position: absolute;
  left: -26px;
  top: 6px;
  width: 76px;
  height: 76px;
  border-radius: 50%;
  background: repeating-radial-gradient(circle, #05070f 0 2px, #0d1430 2px 4px), radial-gradient(circle, #05070f 0 18%, transparent 19%);
  z-index: 1;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  transition: transform .35s ease;
}
.review-card:hover .vinyl-peek { transform: translateX(-10px) rotate(35deg); }
/* ⚠️ FIX: faltaba esta regla. El <img class="album-art"> no tenía
   ancho/alto ni object-fit, así que se pintaba a su tamaño natural
   (las portadas de Spotify suelen venir en 640x640 o más) y rompía
   todo el layout de la tarjeta. Ahora encaja exactamente en el mismo
   espacio de 88x88 que ya reservaba .album-art-wrap, igual que el
   placeholder de abajo. */
.album-art {
  position: relative;
  z-index: 2;
  width: 88px;
  height: 88px;
  border-radius: 10px;
  object-fit: cover;
  display: block;
}
.album-art-placeholder {
  width: 88px;
  height: 88px;
  border-radius: 10px;
  background: linear-gradient(135deg, #1b2750, #0d1430);
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}
.review-content { flex: 1; min-width: 0; }
.album-title { font-size: 14px; font-weight: 700; }
.album-artist { font-size: 12px; color: var(--text-secondary); margin-top: 2px; margin-bottom: 8px; }
.stars { display: flex; gap: 3px; margin-bottom: 8px; }
.star-on, .star-off { width: 13px; height: 13px; }
.star-on { fill: #17d1e8; color: #17d1e8; }
.star-off { fill: rgba(143, 156, 174, 0.3); color: rgba(143, 156, 174, 0.3); }
.review-text {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== EMPTY STATE ===== */
.empty-state { text-align: center; padding: 60px 20px; }
.empty-state svg { width: 48px; height: 48px; color: var(--text-secondary); margin: 0 auto 16px; }
.empty-state h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
.empty-state p { font-size: 13.5px; color: var(--text-secondary); }

@media (max-width: 720px) {
  .profile-content { padding: 24px 18px 60px; }
  .profile-header { flex-direction: column; align-items: center; text-align: center; }
  .profile-stats { justify-content: center; }
}

/* Estados de carga/error para la pestaña "Reseñas" (agregado al
   conectar GET /api/reviews/user/{userId}). */
.detail-status {
  font-size: 13.5px;
  color: var(--text-secondary);
  padding: 16px 0;
}
.detail-status.error {
  color: var(--danger);
}
</file>

