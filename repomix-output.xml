/* ========================================================
   SOUNDRECORDS — LOGIN / REGISTRO
   Tokens tomados del mockup oficial (paleta corporativa)
   ======================================================== */

:host {
  --bg: #0a1128;
  --accent: #17d1e8;
  --accent-2: #9b5de5;
  --text: #ffffff;
  --text-secondary: #8f9cae;
  --card: #131c38;
  --card-border: rgba(143, 156, 174, 0.14);
  --accent-glow: rgba(23, 209, 232, 0.25);
  --danger: #f15f6c;
  --success: #2ee89a;

  display: block;
  font-family: 'Inter', sans-serif;
  color: var(--text);
}

/* ===== CONTENEDOR CENTRADO ===== */
.app-auth {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
  background: radial-gradient(
      circle at 50% 30%,
      rgba(23, 209, 232, 0.07),
      transparent 60%
    ),
    var(--bg);
}

/* ===== TARJETA DE AUTENTICACIÓN ===== */
.auth-box {
  width: 100%;
  max-width: 440px;
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 20px;
  padding: 36px;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
}

/* ===== LOGO ===== */
.auth-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  justify-content: center;
  margin-bottom: 28px;
}

.auth-logo-mark {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: radial-gradient(
      circle at 50% 50%,
      var(--bg) 0 28%,
      transparent 29%
    ),
    conic-gradient(from 180deg, var(--accent), #0a6e7a 40%, var(--accent));
  box-shadow: 0 0 20px var(--accent-glow);
  flex-shrink: 0;
}

.auth-logo-text {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 20px;
  font-weight: 700;

  span {
    color: var(--accent);
  }
}

/* ===== TABS (Iniciar sesión / Crear cuenta) ===== */
.auth-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  padding: 4px;
  margin-bottom: 26px;
}

.auth-tab {
  flex: 1;
  padding: 9px;
  border-radius: 9px;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: center;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  user-select: none;

  &.active {
    background: var(--accent);
    color: var(--bg);
  }
}

/* ===== TÍTULOS ===== */
.auth-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 6px;
  text-align: center;
}

.auth-sub {
  font-size: 13px;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 24px;
}

/* ===== SECCIONES DE FORMULARIO (login / registro) ===== */
.auth-form-section {
  display: none;

  &.active {
    display: block;
  }
}

/* ===== CAMPOS DE FORMULARIO ===== */
.field {
  margin-bottom: 18px;

  label {
    display: block;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 7px;
  }

  input {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--card-border);
    border-radius: 10px;
    padding: 11px 14px;
    font-size: 13.5px;
    color: var(--text);
    font-family: inherit;

    &::placeholder {
      color: var(--text-secondary);
    }

    &:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
  }

  .hint {
    font-size: 11.5px;
    color: var(--text-secondary);
    margin-top: 6px;

    &.error {
      color: var(--danger);
    }
  }

  .hint-link {
    color: var(--accent);
    font-size: 11.5px;
    text-decoration: none;
    cursor: pointer;

    &:hover {
      text-decoration: underline;
    }
  }

  &.invalid input {
    border-color: var(--danger);
    box-shadow: 0 0 0 3px rgba(241, 95, 108, 0.15);
  }
}

.general-error {
  text-align: center;
  margin-bottom: 14px;
}

/* ===== BOTÓN PRIMARIO ===== */
.btn-primary {
  background: var(--accent);
  color: var(--bg);
  font-weight: 700;
  font-size: 14px;
  padding: 13px;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: transform 0.15s, opacity 0.15s;

  &:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  &:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
}

.btn-block {
  width: 100%;
}

/* ===== DIVIDER "o" ===== */
.auth-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 18px 0;

  span {
    font-size: 12px;
    color: var(--text-secondary);
  }

  &::before,
  &::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--card-border);
  }
}

/* ===== BOTÓN SPOTIFY ===== */
.spotify-btn {
  width: 100%;
  padding: 11px;
  border-radius: 10px;
  background: rgba(30, 215, 96, 0.12);
  border: 1px solid rgba(30, 215, 96, 0.3);
  color: #1ed760;
  font-weight: 700;
  font-size: 13.5px;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 4px;
  transition: background 0.15s;

  &:hover {
    background: rgba(30, 215, 96, 0.18);
  }
}

/* ===== FOOTER ===== */
.auth-footer {
  font-size: 12px;
  color: var(--text-secondary);
  text-align: center;
  margin-top: 16px;

  a {
    color: var(--accent);
    text-decoration: none;
    cursor: pointer;

    &:hover {
      text-decoration: underline;
    }
  }
}
</file>

