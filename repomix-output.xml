        Cuenta
      </div>
      <div class="stab" [class.active]="activeTab === 'spotify'" (click)="switchTab('spotify')">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.373 0 12s5.37 12 12 12 12-5.373 12-12S18.63 0 12 0z"/></svg>
        Spotify
      </div>
      <div class="stab" [class.active]="activeTab === 'privacidad'" (click)="switchTab('privacidad')">
