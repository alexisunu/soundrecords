  width: 100%;
  aspect-ratio: 1;
  border-radius: 12px;
  background: linear-gradient(135deg, #1b2750, #0d1430);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
  border: 1px solid var(--card-border);
  overflow: hidden;
}
.discog-cover img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.discog-title {
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 2px;
}
.discog-meta {
  font-size: 11.5px;
  color: var(--text-secondary);
}

/* ===== Reseñas ===== */
.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

/* ===== About ===== */
.artist-about-text {
  font-size: 13.5px;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 18px;
}
.artist-links {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.artist-link {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 20px;
  padding: 6px 14px;
  transition:
    color 0.15s,
    border-color 0.15s;
}
.artist-link:hover {
  color: var(--accent);
  border-color: rgba(23, 209, 232, 0.4);
}
.artist-link svg {
  width: 14px;
  height: 14px;
}

/* ===== Rail ===== */
.artist-rail {
  padding: 24px 20px 60px;
  border-left: 1px solid var(--card-border);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.rail-card {
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 14px;
  padding: 16px;
}
.rail-card h3 {
  font-size: 13.5px;
  font-weight: 700;
  margin-bottom: 10px;
}
.rail-hint {
  font-size: 12.5px;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 12px;
}

/* ===== Botones ===== */
.btn-ghost {
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
  border: 1px solid rgba(23, 209, 232, 0.4);
  border-radius: 10px;
  padding: 9px 18px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: transparent;
  font-family: inherit;
  cursor: pointer;
}
.btn-ghost:hover:not(:disabled) {
  background: rgba(23, 209, 232, 0.07);
}
.btn-ghost.icon-only {
  padding: 10px 14px;
}

.btn-primary {
  font-size: 13px;
  font-weight: 700;
  color: #04121c;
  background: var(--accent);
  border: none;
  border-radius: 10px;
  padding: 10px 20px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  cursor: pointer;
  font-family: inherit;
}
.btn-primary:hover:not(:disabled) {
  filter: brightness(1.08);
}
.btn-primary:disabled {
  opacity: 0.6;
  cursor: default;
}
.btn-primary.following {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--card-border);
